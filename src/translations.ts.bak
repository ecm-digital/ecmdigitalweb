        "notFound.button": "← Strona główna",

        // Privacy Page
        "privacy.title": "Polityka Prywatności",
        "privacy.intro": "Niniejsza Polityka prywatności określa zasady gromadzenia, przetwarzania i ochrony danych osobowych użytkowników serwisu ECM Digital.",
        "privacy.s1.title": "1. Administrator Danych",
        "privacy.s1.text": "Administratorem danych osobowych jest ECM Digital z siedzibą w Warszawie.",
        "privacy.s2.title": "2. Zakres zbieranych danych",
        "privacy.s2.text": "Zbieramy dane podane dobrowolnie w formularzach kontaktowych (Imię, nazwisko, e-mail, nazwa firmy) oraz dane zbierane automatycznie przez narzędzia analityczne (Google Analytics, Hotjar, PostHog).",
        "privacy.s3.title": "3. Cel przetwarzania",
        "privacy.s3.text": "Dane są przetwarzane w celu obsługi zapytań, marketingu bezpośredniego oraz analizy statystycznej ruchu na stronie.",
        "privacy.s4.title": "4. Pliki Cookies",
        "privacy.s4.text": "Strona używa plików cookies w celu poprawy jakości usług. Użytkownik może zarządzać ustawieniami cookies w swojej przeglądarce.",

