        // Process
        "process.label": "Customer Experience 2.0",
        "process.title": "Autorski Proces & The Portal",
        "process.subtitle": "Zapomnij o chaotycznych mailach. U nas cały proces – od pomysłu po start projektu – śledzisz w autorskim panelu The Portal Client, który zapewnia 100% transparentności i doskonałą współpracę.",
        "process.step1.title": "Audyt & Onboarding",
        "process.step1.desc": "Zaczynamy od sesji strategicznej. Otrzymujesz bezpieczny dostęp do The Portal, gdzie znajduje się mapa Twojego projektu, harmonogram oraz kluczowe pliki.",
        "process.step2.title": "Progres na Żywo",
        "process.step2.desc": "Koniec z pytaniem \"czym się teraz zajmujecie?\". Nasz system w czasie rzeczywistym aktualizuje status wdrożenia i informuje Cię o zrealizowanych kamieniach milowych.",
        "process.step3.title": "Transparentny Development",
        "process.step3.desc": "Przez cały okres kodowania i implementacji AI masz dostęp do środowiska testowego z poziomu panelu. Wszelkie akceptanty (np. projekty UI) i feedback klikasz w jednym miejscu.",
        "process.step4.title": "Launch & Baza Wiedzy (Support)",
        "process.step4.desc": "Oddajemy Ci w pełni działający produkt. The Portal zostaje z Tobą na zawsze – to w nim masz ustrukturyzowaną bazę nagrań VOD ze szkoleń wdrożeniowych z AI i miejsce do ticketów dla supportu.",

        // Testimonials
        "testimonials.label": "Opinie klientów",
        "testimonials.title": "Co Mówią Nasi Klienci",
        "testimonials.subtitle": "Opinie firm, które współpracowały z nami",
        "testimonials.t1.text": "Wdrożyli nam agenta AI obsługującego 80% zapytań klientów automatycznie. Miałem pełen podgląd postępów w The Portal – wiedziałem dokładnie na jakim etapie jest projekt. Czas odpowiedzi na leady spadł z 4h do 2 minut.",
        "testimonials.t1.name": "Tomasz Wróblewski",
        "testimonials.t1.role": "CEO, Automatica Group",
        "testimonials.t2.text": "Headless Shopify + system rekomendacji AI. W trzy miesiące od launchu: +187% konwersji i średni koszyk z 89 zł na 156 zł. Kampanie na Metach też im oddaliśmy – ROAS 11x w pierwszym miesiącu.",
        "testimonials.t2.name": "Karolina Mazur",
        "testimonials.t2.role": "Founder, LUMINA Cosmetics",
        "testimonials.t3.text": "Potrzebowaliśmy MVP aplikacji mobilnej do walidacji pomysłu z inwestorami. ECM dowiezione w 8 tygodni – apka w App Store, onboarding klientów gotowy, panel admina działa. Dzięki panelowi klienta widziałem każdy sprint na żywo.",
        "testimonials.t3.name": "Michał Zieliński",
        "testimonials.t3.role": "Co-Founder, FinBridge",
        "testimonials.t4.text": "Innowacyjne podejście do AI. Ich agenci zrewolucjonizowali naszą obsługę klienta.",
        "testimonials.t4.name": "Adam Kowalczyk",
        "testimonials.t4.role": "CEO, FutureNet",
        "testimonials.t5.text": "Projekt strony WWW przekroczył nasze oczekiwania. Design jest nowoczesny i bardzo szybki.",
        "testimonials.t5.name": "Marta Głowacka",
        "testimonials.t5.role": "Marketing Director, ArtStyle",

        // FAQ
        "faq.label": "FAQ",
        "faq.title": "Często Zadawane Pytania",
        "faq.subtitle": "Odpowiedzi na najczęściej zadawane pytania",
        "faq.q1": "Ile trwa realizacja typowego projektu?",
        "faq.a1": "Czas realizacji zależy od złożoności projektu. Strona WWW to 2–4 tygodnie, sklep e-commerce 4–6 tygodni, a aplikacja mobilna 8–12 tygodni. Każdy projekt zaczynamy od szczegółowej analizy i harmonogramu.",
        "faq.q2": "Ile kosztuje wdrożenie rozwiązania AI?",
        "faq.a2": "Koszt wdrożenia AI zależy od zakresu prac. Podstawowy agent AI / chatbot to od 4,500 PLN, a zaawansowany system z integracjami od 12,000 PLN. Oferujemy darmową konsultację dla dokładnej wyceny.",
        "faq.q3": "Czy oferujecie wsparcie po wdrożeniu?",
        "faq.a3": "Tak! Każdy projekt objęty jest 30-dniowym wsparciem gwarancyjnym. Dodatkowo oferujemy pakiety wsparcia miesięcznego obejmujące aktualizacje, monitoring i optymalizację.",
        "faq.q4": "Jakie technologie wykorzystujecie?",
        "faq.a4": "Pracujemy z najnowszymi technologiami: Next.js, React, React Native, Google Gemini AI, N8N, Shopify, Wix, Firebase, AWS i wiele innych. Dobieramy stack technologiczny do potrzeb projektu.",
        "faq.q5": "Czy mogę zobaczyć portfolio?",
        "faq.a5": "Oczywiście! Nasze realizacje znajdziesz w sekcji Portfolio powyżej. Chętnie pokażemy też szczegółowe case studies podczas konsultacji.",

